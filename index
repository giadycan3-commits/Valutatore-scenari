async function procFile(f){
  document.getElementById('fname').textContent=f.name;
  document.getElementById('fpill').style.display='flex';
  document.getElementById('tc').style.display='block';

  if(f.type==='text/plain'){
    const r=new FileReader();
    r.onload=e=>{ document.getElementById('rt1').value=e.target.result; };
    r.readAsText(f);
    return;
  }

  if(f.type==='application/pdf'||f.name.toLowerCase().endsWith('.pdf')){
    document.getElementById('rt1').value='⏳ Estrazione testo dal PDF in corso...';
    try {
      const pdfjsLib=window['pdfjs-dist/build/pdf'];
      if(!pdfjsLib.GlobalWorkerOptions.workerSrc) pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
      const buf=await f.arrayBuffer();
      const pdf=await pdfjsLib.getDocument({data:buf}).promise;
      let fullText='';
      for(let p=1;p<=pdf.numPages;p++){
        const page=await pdf.getPage(p);
        const tc=await page.getTextContent();
        const pageText=tc.items.map(i=>i.str).join(' ');
        fullText+=pageText+'\n';
      }
      fullText=fullText.trim();
      if(!fullText) throw new Error('Nessun testo estraibile (PDF scansionato?)');
      document.getElementById('rt1').value=fullText;
      console.log('[PDF] Estratti',fullText.length,'caratteri da',pdf.numPages,'pagine');
    } catch(err){
      document.getElementById('rt1').value='';
      alert('Errore estrazione PDF: '+err.message+'\n\nIncolla il testo manualmente nella casella in basso.');
      console.error(err);
    }
    return;
  }

  // fallback altri formati
  const r=new FileReader();
  r.onload=e=>{ document.getElementById('rt1').value=new TextDecoder().decode(e.target.result); };
  r.readAsArrayBuffer(f);
}
