        <div class="motiv ${motCls}">${motTxt}</div>
        ${pf||ac?`<div class="dgrid">
          <div class="dbox pos"><h5>Punti di forza</h5><ul style="color:var(--green)">${pf||'<li style="color:var(--text3)">—</li>'}</ul></div>
          <div class="dbox neg"><h5>Aspetti da consolidare</h5><ul style="color:var(--red)">${ac||'<li style="color:var(--text3)">—</li>'}</ul></div>
        </div>`:''}
      </div>
    </div>`;
  }
  document.getElementById('rcontent').innerHTML=html;

  document.getElementById('stat-box').style.display='block';
  document.getElementById('stat-body').innerHTML=`
    <div style="color:var(--green)">✓ ${s.confermati} confermati</div>
    <div style="color:var(--amber)">⚠ ${s.parziali} parziali</div>
    <div style="color:var(--red)">✗ ${s.non_confermati} non confermati</div>`;
}

function resetApp(){
  figura=null; analisiData=null; workbooks={};
  ['fc-ata','fc-doc'].forEach(id=>document.getElementById(id).classList.remove('sel'));
  document.getElementById('btn1').disabled=true;
  document.getElementById('hpill').style.display='none';
  document.getElementById('fpill').style.display='none';
  document.getElementById('rt1').value=''; document.getElementById('rt2').value='';
  document.getElementById('tc').style.display='none';
  document.getElementById('sumgrid').innerHTML=''; document.getElementById('rcontent').innerHTML='';
  document.getElementById('dl-grid').innerHTML=''; document.getElementById('nota-gen-box').innerHTML='';
  document.getElementById('stat-box').style.display='none';
  gp(1);
}

function showLoad(m){document.getElementById('loading').classList.add('show');document.getElementById('lmsg').textContent=m;}
function updLoad(m){document.getElementById('lmsg').textContent=m;}
function hideLoad(){document.getElementById('loading').classList.remove('show');}
</script>
