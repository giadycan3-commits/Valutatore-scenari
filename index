async function avvia(){
  const testo=(document.getElementById('rt1').value.trim()||document.getElementById('rt2').value.trim());
  if(!testo){alert('Inserisci o carica il testo del report.');return;}
  if(!figura){alert('Seleziona prima la figura.');return;}

  const rigor=document.getElementById('rigor').value;
  const tmpl=TEMPLATES[figura];

  const rigorMap={
    standard:'Mite: valorizza gli elementi positivi presenti. Conferma il livello anche con evidenze parziali, declassa solo in caso di assenza totale di elementi coerenti.',
    critico:'Critico: in dubbio declassa. Genericità non giustifica L3/L4.',
    severo:'Molto critico: declassa se mancano prove concrete di leadership/innovazione sistemica.'
  };

  // Schema indicatori compatto
  let schemaInd='';
  for(const [aId,aD] of Object.entries(tmpl))
    for(const sh of aD.sheets)
      schemaInd+=`${aId} C${sh.comp}: ${sh.indicators.join(', ')}\n`;

  const figPfx=figura==='ATA'?'ATA':'DOC';

  const systemMsg=`Sei valutatore DigCompEdu per ${figura}. Rigore: ${rigorMap[rigor]}

SOGLIE:
L1: agisce solo su indicazione, no autonomia, no confronto, no pianificazione.
L2: autonomia su compiti assegnati, criteri base, inizia metodo personale.
L3: strategie proprie documentate, valutazione critica autonoma, condivisione sistematica con ricadute osservabili.
L4: progettazione sistemica scalabile, forma/guida altri strutturalmente, policy d'istituto, disseminazione esterna.

INDICATORI ${figura}:
${schemaInd}

FORMATO: casi di studio narrativi ATA. Livello nel titolo ("Studio di caso L2"). Fasi numerate corrispondono agli indicatori.

RIFERIMENTI PER CAPIRE IL FORMATO ATA:
- I casi ATA descrivono situazioni operative concrete (email, cloud, turni, laboratori, comunicazioni di servizio)
- Le fasi non citano codici indicatori ma azioni operative (es. "Fase 1. Rileva criticità...", "Fase 2. Analizza...")
- La sottocompetenza si ricava dal TITOLO del documento (es. "NETIQUETTE" → comp 2.5, area A2; "CONDIVIDERE LE INFORMAZIONI" → comp 2.2, area A2; "Gestire l'identità digitale" → comp 2.6, area A2; "COLLABORARE ATTRAVERSO LE TECNOLOGIE DIGITALI" → comp 2.4, area A2)
- Per ATA area A1: "Navigare ricercare" → 1.1, "Valutare dati" → 1.2, "Gestire organizzare" → 1.3
- Per ATA area A2: "Interagire" → 2.1, "Condividere informazioni" → 2.2, "Cittadinanza digitale" → 2.3, "Collaborare" → 2.4, "Netiquette" → 2.5, "Identità digitale" → 2.6

REGOLE:
- Il livello presente nel documento NON è autodichiarato dal soggetto ma assegnato da un sistema automatizzato esterno. Usa sempre questa terminologia: "livello assegnato" (non "livello dichiarato"), "livello rilevato dall'analisi" (non "livello che il soggetto si attribuisce").
- Nel testo delle motivazioni NON scrivere mai frasi come "il soggetto dichiara L4" o "il candidato afferma di essere a L3". Usa invece: "il livello assegnato dal sistema è L4", "dall'analisi del caso emerge L3", "il profilo descritto corrisponde a L2".
- Il testo descrive un profilo ideale: valuta se le azioni descritte sono coerenti e plausibili con il livello assegnato.
- Per ATA: L3 richiede intervento autonomo su situazione complessa + proposta ai colleghi. L4 richiede progettazione di sistema condiviso + formazione/guida strutturata di altri + impatto organizzativo.
- Genericità senza nessun elemento concreto = declassa. Ma presenza di dettagli operativi specifici = conferma.
- Identifica sottocompetenza dal TITOLO del documento, non dalle fasi.

OUTPUT: JSON puro, zero testo esterno.

LUNGHEZZA TESTI — rispetta questi limiti TASSATIVI:
- motivazione_si / motivazione_no / motivazione_dubbio: OBBLIGATORIO, sempre presente anche se breve. Max 5 frasi. Cita elementi specifici del testo.
- punti_forza: OBBLIGATORIO, sempre presente. Max 2 punti, 1 frase ciascuno.
- aspetti_consolidare: OBBLIGATORIO, sempre presente. Max 2 punti, 1 frase ciascuno.
- motivazione_analisi: OBBLIGATORIO, sempre presente. Min 2 frasi, max 5 frasi.
- nota_generale: OBBLIGATORIO, sempre presente. Max 3 frasi.
- Non lasciare MAI un campo vuoto o con stringa vuota "". Se il verdetto è "si", compila motivazione_si. Se "no", compila motivazione_no. Se "dubbio", compila motivazione_dubbio.

Schema: {"figura":"${figura}","sottocompetenza_rilevata":"1.1","area_rilevata":"A1","filename_output":"${figPfx}-A1-C1.1-valutazione.xlsx","sommario":{"totale":0,"confermati":0,"parziali":0,"non_confermati":0,"nota_generale":"max 2 frasi"},"indicatori":{"1.1.1":{"livello_assegnato":"L4","livello_rilevato":"L3","verdetto":"no","motivazione_si":"","motivazione_no":"max 2 frasi","motivazione_dubbio":"","punti_forza":"punto 1; punto 2","aspetti_consolidare":"lacuna 1; lacuna 2","motivazione_analisi":"max 3 frasi"}}}`;

  // Troncatura intelligente: mantieni inizio + fine (titolo + livello + conclusioni)
  const MAX=28000;
  let testoOk=testo;
  if(testo.length>MAX){
    const head=testo.substring(0,Math.round(MAX*0.7));
    const tail=testo.substring(testo.length-Math.round(MAX*0.3));
    testoOk=head+'\n\n[...testo centrale omesso per lunghezza...]\n\n'+tail;
    console.log('[Troncatura] Originale:',testo.length,'→ Inviato:',testoOk.length,'caratteri');
  }

  showLoad('Analisi AI in corso...');

  try {
    updLoad('Elaborazione caso di studio...');
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:6000,
        system:systemMsg,
        messages:[{role:'user',content:'Analizza e restituisci SOLO il JSON:\n\n'+testoOk}]
      })
    });

    if(!res.ok){
      const errBody=await res.text().catch(()=>'no body');
      throw new Error(`HTTP ${res.status}: ${errBody.substring(0,400)}`);
    }

    const data=await res.json();
    if(data.error) throw new Error(`API: ${data.error.type} — ${data.error.message}`);
    if(!data.content||!data.content.length) throw new Error('Risposta API vuota');

    const raw=data.content.map(b=>b.text||'').join('');
    console.log('[AI raw] lunghezza risposta:', raw.length, 'primi 200 car:', raw.substring(0,200));

    // Parser JSON robusto: trova il primo { e l'ultimo } bilanciati
    let parsed = null;
    const firstBrace = raw.indexOf('{');
    const lastBrace = raw.lastIndexOf('}');
    if(firstBrace === -1 || lastBrace === -1 || lastBrace <= firstBrace){
      throw new Error('Nessun JSON trovato nella risposta AI: '+raw.substring(0,400));
    }
    const jsonStr = raw.substring(firstBrace, lastBrace+1);
    try {
      parsed = JSON.parse(jsonStr);
    } catch(parseErr){
      // Prova a fare cleanup del JSON (virgole finali, caratteri speciali)
      const cleaned = jsonStr
        .replace(/,\s*([}\]])/g, '$1')   // trailing commas
        .replace(/[\x00-\x1F\x7F]/g, ' '); // control chars
      try {
        parsed = JSON.parse(cleaned);
      } catch(e2){
        console.error('[JSON parse fail] stringa:', jsonStr.substring(0,500));
        throw new Error('Parsing JSON fallito: '+parseErr.message+'. Primi 300 char: '+jsonStr.substring(0,300));
      }
    }
    analisiData = parsed;
    console.log('[AI parsed] sottocomp:', analisiData.sottocompetenza_rilevata, 'area:', analisiData.area_rilevata, 'indicatori:', Object.keys(analisiData.indicatori||{}).join(', '));

    updLoad('Generazione xlsx...');
    await new Promise(r=>setTimeout(r,150));

    const compCode=analisiData.sottocompetenza_rilevata;
    const areaId=analisiData.area_rilevata;

    if(!compCode || !areaId){
      throw new Error(`L'AI non ha identificato sottocompetenza (${compCode}) o area (${areaId}). Verifica che il PDF contenga un titolo come "1.1 Comunicazione organizzativa" o "Studio di caso L3".`);
    }

    const areaData=TEMPLATES[figura]?.[areaId];
    const sheetDef=areaData?.sheets?.find(s=>s.comp===compCode);

    if(!sheetDef){
      // Prova a trovare l'area automaticamente cercando tra tutti i template
      let foundSheet=null, foundArea=null;
      for(const [aid,ad] of Object.entries(TEMPLATES[figura])){
        const s=ad.sheets.find(sh=>sh.comp===compCode);
        if(s){ foundSheet=s; foundArea=aid; break; }
      }
      if(foundSheet){
        console.warn(`[Fix] Area corretta automaticamente: ${areaId} → ${foundArea}`);
        analisiData.area_rilevata=foundArea;
        workbooks={single:buildSingleSheet(foundSheet,analisiData.indicatori,analisiData.filename_output||`${figPfx}-${foundArea}-C${compCode}-valutazione.xlsx`)};
      } else {
        throw new Error(`Sottocompetenza "${compCode}" non trovata nei template per ${figura}. Indicatori disponibili: ${Object.keys(analisiData.indicatori||{}).join(', ')}`);
      }
    } else {
      workbooks={single:buildSingleSheet(sheetDef,analisiData.indicatori,analisiData.filename_output||`${figPfx}-${areaId}-C${compCode}-valutazione.xlsx`)};
    }

    renderRisultati(analisiData);
    renderDownloads();
    gp(4);
  } catch(err){
    alert('Errore analisi:\n'+err.message+'\n\nAprire la console per dettagli.');
    console.error('[DigCompEdu Valutatore]',err);
  } finally { hideLoad(); }
}

