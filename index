function buildSingleSheet(sheetDef, indicatori, filename){
  const wb=XLSX.utils.book_new();
  const inds=sheetDef.indicators;

  const row0=['Elementi di analisi','',...inds];
  const row1=['Conferma il livello attribuito col feedback','sì, perché...\u00a0',...inds.map(id=>{
    const d=indicatori[id]; if(!d) return '';
    return d.verdetto==='si'?(d.motivazione_si||''):'';
  })];
  const row2=['','no, perché...\u00a0',...inds.map(id=>{
    const d=indicatori[id]; if(!d) return '';
    return d.verdetto==='no'?(d.motivazione_no||''):'';
  })];
  const row3=['','sono in dubbio perché...\u00a0',...inds.map(id=>{
    const d=indicatori[id]; if(!d) return '';
    return d.verdetto==='dubbio'?(d.motivazione_dubbio||''):'';
  })];
  const row4=['Livello attribuito','',...inds.map(id=>{
    const d=indicatori[id];
    return d?(d.livello_rilevato||d.livello_assegnato||d.livello_dichiarato||''):'';
  })];
  const row5=['Osservazioni di accompagnamento','motivazione',...inds.map(id=>{
    const d=indicatori[id];
    return d?(d.motivazione_analisi||d.motivazione_si||d.motivazione_no||d.motivazione_dubbio||''):'';
  })];
  const row6=['','punti di forza\u00a0',...inds.map(id=>{
    const d=indicatori[id]; return d?(d.punti_forza||''):'';
  })];
  const row7=['','aspetti da consolidare',...inds.map(id=>{
    const d=indicatori[id]; return d?(d.aspetti_consolidare||''):'';
  })];

  const ws=XLSX.utils.aoa_to_sheet([row0,row1,row2,row3,row4,row5,row6,row7]);
  ws['!cols']=[{wch:40},{wch:30},...inds.map(()=>({wch:42}))];
  ws['!rows']=[{hpt:18},{hpt:90},{hpt:90},{hpt:70},{hpt:22},{hpt:90},{hpt:70},{hpt:70}];
  XLSX.utils.book_append_sheet(wb, ws, sheetDef.name);

  wb._filename=filename;
  return wb;
}

function downloadXlsx(){
  const wb=workbooks.single;
